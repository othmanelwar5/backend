APP_ENV=production
API_BASE_URL=https://api.mymizan.shop
FRONTEND_ORIGIN=https://mymizan.shop

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@mymizan_database:5432/mymizan
RUN_MIGRATIONS_ON_STARTUP=true

ORDER_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ── Admin dashboard ──────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-long-random-password

# ── MaxMind GeoIP2 Precision (Insights) ──────────────────────────
# Sign up: https://www.maxmind.com/en/geoip2-precision-insights
# Account ID and License Key from your MaxMind account dashboard.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
MAXMIND_ENABLED=true

# Geo-fraud settings
GEO_ALLOWED_COUNTRIES=["SA"]
GEO_BLOCK_VPN=true
GEO_BLOCK_HIGH_RISK=true
GEO_RISK_SCORE_THRESHOLD=50.0

# Optional secondary VPN/proxy detection provider.
# The backend sends GET {VPN_DETECTION_API_URL}?ip=CLIENT_IP with Bearer auth.
VPN_DETECTION_API_URL=
VPN_DETECTION_API_KEY=

# Whitelisted phone numbers bypass geo/fraud checks (comma-separated in JSON array)
# Use for testing orders in production
WHITELISTED_PHONES=["055000000"]

# ── Meta CAPI ────────────────────────────────────────────────────
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# ── TikTok CAPI ─────────────────────────────────────────────────
TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

# ── Snapchat CAPI ───────────────────────────────────────────────
SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=

CAPI_ENABLED=true
CAPI_TEST_MODE=false
